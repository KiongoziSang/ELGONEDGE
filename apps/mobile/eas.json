{
  "cli": {
    "version": ">= 14.0.0"
  },
  "build": {
    "development": {
      "developmentClient": true,
      "distribution": "internal"
    },
    "preview": {
      "distribution": "internal",
      "android": {
        "buildType": "apk"
      },
      "env": {
        "EXPO_PUBLIC_API_BASE_URL": "https://elgonos.elgonedge.com",
        "EXPO_PUBLIC_USE_MOCKS": "false"
      }
    },
    "production": {
      "autoIncrement": true,
      "env": {
        "EXPO_PUBLIC_API_BASE_URL": "https://elgonos.elgonedge.com",
        "EXPO_PUBLIC_USE_MOCKS": "false"
      }
    }
  },
  "submit": {
    "production": {}
  }
}
