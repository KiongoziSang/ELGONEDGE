{
  "expo": {
    "name": "ElgonOS Mobile",
    "slug": "elgonos-mobile",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/elgonos-logo.png",
    "splash": {
      "image": "./assets/elgonos-logo.png",
      "resizeMode": "contain",
      "backgroundColor": "#0A1B2E"
    },
    "scheme": "elgonos",
    "userInterfaceStyle": "light",
    "ios": {
      "supportsTablet": true
    },
    "android": {
      "package": "com.elgonedge.elgonos",
      "adaptiveIcon": {
        "backgroundColor": "#0A1B2E",
        "foregroundImage": "./assets/elgonos-logo.png",
        "backgroundImage": "./assets/android-icon-background.png",
        "monochromeImage": "./assets/android-icon-monochrome.png"
      },
      "predictiveBackGestureEnabled": false
    },
    "web": {
      "favicon": "./assets/elgonos-logo.png"
    },
    "plugins": [
      "expo-secure-store",
      [
        "expo-image-picker",
        {
          "photosPermission": "Allow ElgonOS to attach item photos to resident exchange listings."
        }
      ]
    ]
  }
}
